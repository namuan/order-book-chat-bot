# --- Vector search / embedding ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHROMA_PERSIST_DIR=./data/chroma
COLLECTION_NAME=order_guides
DOCS_COLLECTION_NAME=documents

# --- PDF table extraction ---
# Comma-separated, tried in order. Fallbacks are only consulted when the
# previous backend returned no tables AND the page has at least
# PDF_TABLE_MIN_CHARS characters of text.
#   pdfplumber  - always-on, fast, good for bordered tables
#   camelot     - needs `uv sync --extra pdf-camelot` and Ghostscript
#   vision      - needs an API key (OPENAI_API_KEY or ANTHROPIC_API_KEY)
#   none        - text only
PDF_TABLE_BACKENDS=pdfplumber
PDF_TABLE_MIN_CHARS=80

# --- Vision LLM (used only when PDF_TABLE_BACKENDS includes "vision") ---
PDF_VISION_PROVIDER=openai        # openai | anthropic
PDF_VISION_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=...

# --- Chat / LLM ---
# Leave LLM_PROVIDER=stub to run without an LLM (echoes retrieved context).
# Set to "openai" and provide OPENAI_API_KEY for real chat.
LLM_PROVIDER=stub
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- API ---
HOST=127.0.0.1
PORT=8000
